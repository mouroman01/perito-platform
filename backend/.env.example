# Banco de Dados
DATABASE_URL=postgresql+psycopg2://perito_os:perito_os@localhost:5432/perito_os

# Segurança / JWT
SECRET_KEY=troque-esta-chave-em-producao
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=perito_os
MINIO_SECRET_KEY=troque-esta-chave-em-producao
MINIO_BUCKET=perito-os
MINIO_SECURE=false

# API
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
ENVIRONMENT=development

# Inteligência Artificial (Anthropic / Claude) — RF015
# Obtenha a chave em https://console.anthropic.com e cole aqui (não versione).
# Sem a chave, os recursos de IA respondem 503 com mensagem explicativa.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
